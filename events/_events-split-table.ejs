<%
function parseEventDate(value) {
  if (!value) return null;

  if (value instanceof Date && !isNaN(value.getTime())) {
    return new Date(value.getFullYear(), value.getMonth(), value.getDate());
  }

  const s = String(value).trim();

  let m = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (m) {
    return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
  }

  m = s.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
  if (m) {
    return new Date(Number(m[3]), Number(m[2]) - 1, Number(m[1]));
  }

  const d = new Date(s);
  if (!isNaN(d.getTime())) {
    return new Date(d.getFullYear(), d.getMonth(), d.getDate());
  }

  return null;
}

function formatDateEN(value) {
  const d = parseEventDate(value);

  if (!d) return value || "";

  return new Intl.DateTimeFormat("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric"
  }).format(d);
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = [];
const past = [];

for (const item of items) {
  const eventDate = parseEventDate(item.start_date || item.date);

  if (eventDate && eventDate >= today) {
    upcoming.push(item);
  } else {
    past.push(item);
  }
}

upcoming.sort((a, b) => {
  return parseEventDate(a.start_date || a.date) - parseEventDate(b.start_date || b.date);
});

past.sort((a, b) => {
  return parseEventDate(b.start_date || b.date) - parseEventDate(a.start_date || a.date);
});

function renderTable(eventItems) {
%>
<table class="table table-striped table-hover event-table list">
  <thead>
    <tr>
      <th>Date</th>
      <th>Event</th>
      <th>Location</th>
    </tr>
  </thead>
  <tbody>
  <% for (const item of eventItems) { %>
    <tr <%= metadataAttrs(item) %>>
      <td class="listing-date">
        <%- formatDateEN(item.start_date || item.date) %>
      </td>

      <td class="listing-title">
        <% if (item.link) { %>
          <a href="<%- item.link %>" target="_blank" rel="noopener">
            <%- item.title || "" %>
          </a>
        <% } else { %>
          <%- item.title || "" %>
        <% } %>
      </td>

      <td class="listing-location"><%- item.location || "" %></td>
    </tr>
  <% } %>
  </tbody>
</table>
<%
}
%>

<h2>Upcoming events</h2>

<% if (upcoming.length > 0) { %>
  <% renderTable(upcoming); %>
<% } else { %>
  <p>No upcoming events.</p>
<% } %>

<h2>Past events</h2>

<% if (past.length > 0) { %>
  <% renderTable(past); %>
<% } else { %>
  <p>No past events.</p>
<% } %>
```
