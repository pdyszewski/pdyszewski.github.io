```{=html}
<div class="presentation-list list">
<% for (const item of items) {
  const year = item.date ? new Date(item.date).getFullYear() : "";
%>
  <article class="presentation-item" <%= metadataAttrs(item) %>>
    <div class="presentation-year listing-date"><%- year %></div>

    <div class="presentation-main">
      <div class="presentation-body">
        <div class="presentation-type listing-type">
          <%- item.type || "" %>
        </div>

<h3 class="presentation-title listing-title">
  <%- item.title || "" %>
</h3>
        <% if (item.event) { %>
          <div class="presentation-event listing-event">
            <em><%- item.event %></em>
          </div>
        <% } %>

        <% if (item.location) { %>
          <div class="presentation-location listing-location">
            <%- item.location %>
          </div>
        <% } %>

        <% if (item.description) { %>
          <p class="presentation-description">
            <%- item.description %>
          </p>
        <% } %>

        <div class="presentation-links">
          <% if (item.slides) { %>
            <a href="<%- item.slides %>">Slides</a>
          <% } %>

          <% if (item.video) { %>
            <a href="<%- item.video %>">Video</a>
          <% } %>

          <% if (item.code) { %>
            <a href="<%- item.code %>">Code</a>
          <% } %>

          <% if (item.poster) { %>
            <a href="<%- item.poster %>">Poster</a>
          <% } %>
        </div>
      </div>

      <% if (item.image) { %>
        <div class="presentation-image-wrap">
          <img
            class="presentation-image"
            src="<%- item.image %>"
            alt="<%- item.image_alt || item.title || 'Presentation image' %>"
            loading="lazy"
          />
        </div>
      <% } %>
    </div>
  </article>
<% } %>
</div>
```
